# Node.js Environment
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Azure SQL Database
# Get from Azure Portal → SQL Database → Connection Strings
DATABASE_URL="sqlserver://YOUR_SERVER.database.windows.net:1433;database=jvpay;user=YOUR_USERNAME;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=false"

# Azure Storage (same as ai-engine)
# Get from Azure Portal → Storage Account → Access Keys
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=YOUR_STORAGE_ACCOUNT;AccountKey=YOUR_STORAGE_KEY;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER_NAME=jvpay-docs

# Azure AD (Optional - for authentication)
# Get from Azure Portal → App Registrations
AZURE_TENANT_ID=YOUR_TENANT_ID
AZURE_CLIENT_ID=YOUR_CLIENT_ID

# Python AI Engine
AI_ENGINE_URL=http://localhost:8000

# LangSmith (set in Sprint 3)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
