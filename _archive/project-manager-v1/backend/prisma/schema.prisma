// Prisma schema for Invoice Validation & Review Platform
// 36 tables across 15 families — Azure SQL (SQL Server)
// Generated: 2 July 2026

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 1 — IDENTITY & ACCESS
// ═══════════════════════════════════════════════════════════════════════════════

model Client {
  id           Int       @id @default(autoincrement())
  name         String
  code         String    @unique
  address      String?
  contactEmail String?   @map("contact_email")
  contactPhone String?   @map("contact_phone")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  users     User[]
  userRoles UserRole[]
  contracts Contract[]
  packages  Package[]

  @@index([isActive])
  @@map("clients")
}

model User {
  id           Int       @id @default(autoincrement())
  clientId     Int?      @map("client_id")
  email        String    @unique
  displayName  String    @map("display_name")
  jobTitle     String?   @map("job_title")
  passwordHash String?   @map("password_hash")
  entraOid     String?   @unique @map("entra_oid")
  lastLoginAt  DateTime? @map("last_login_at")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  client   Client? @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  sessions               UserSession[]
  userRoles              UserRole[]
  grantedRoles           UserRole[]              @relation("GrantedByUser")
  contractsCreated       Contract[]
  contractsConfigured    ContractConfig[]
  packagesSubmitted      Package[]               @relation("SubmittedByUser")
  packagesReviewed       Package[]               @relation("ReviewedByUser")
  packagesApproved       Package[]               @relation("ApprovedByUser")
  packagesCreated        Package[]               @relation("CreatedByUser")
  documentsUploaded      PackageDocument[]
  agentPlansConfirmed    AgentPlan[]
  validationRuns         ValidationRun[]
  exceptionResolutions   ExceptionResolution[]
  reviewActionLogs       ReviewActionLog[]
  auditEvents            AuditEvent[]
  dataChangeLogs         DataChangeLog[]
  notifications          Notification[]
  notificationPrefs      NotificationPreference[]
  systemConfigsUpdated   SystemConfig[]

  @@index([clientId])
  @@index([isActive])
  @@map("users")
}

model Role {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  displayName String  @map("display_name")
  description String?
  isActive    Boolean @default(true) @map("is_active")

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  roleId       Int       @map("role_id")
  clientId     Int?      @map("client_id")
  grantedBy    Int?      @map("granted_by")
  grantedAt    DateTime  @default(now()) @map("granted_at")
  revokedAt    DateTime? @map("revoked_at")
  revokeReason String?   @map("revoke_reason")

  user      User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  role      Role    @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  client    Client? @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  grantedByUser User? @relation("GrantedByUser", fields: [grantedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, roleId, clientId])
  @@index([userId])
  @@index([clientId])
  @@index([roleId])
  @@map("user_roles")
}

model UserSession {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  sessionToken String    @unique @map("session_token")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")
  expiresAt    DateTime  @map("expires_at")
  lastActiveAt DateTime? @map("last_active_at")
  revokedAt    DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 2 — CONTRACT MASTER
// ═══════════════════════════════════════════════════════════════════════════════

model Contract {
  id                  Int       @id @default(autoincrement())
  clientId            Int       @map("client_id")
  contractNo          String?   @map("contract_no")
  contractName        String    @map("contract_name")
  contractorName      String?   @map("contractor_name")
  ownerName           String?   @map("owner_name")
  projectDescription  String?   @map("project_description")
  projectLocation     String?   @map("project_location")
  contractStartDate   DateTime? @map("contract_start_date")
  contractEndDate     DateTime? @map("contract_end_date")
  originalContractSum Decimal?  @map("original_contract_sum")
  currency            String    @default("USD")
  isActive            Boolean   @default(true) @map("is_active")
  createdBy           Int?      @map("created_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime? @updatedAt @map("updated_at")

  client    Client  @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator   User?   @relation(fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  config    ContractConfig?
  packages  Package[]

  @@index([clientId])
  @@index([isActive])
  @@index([contractNo])
  @@map("contracts")
}

model ContractConfig {
  id                              Int       @id @default(autoincrement())
  contractId                      Int       @unique @map("contract_id")
  retainageRatePct                Decimal   @default(10.0) @map("retainage_rate_pct")
  retainageAppliesTo              String    @default("BOTH") @map("retainage_applies_to")
  retainageReleaseThresholdPct    Decimal?  @default(50.0) @map("retainage_release_threshold_pct")
  maxRetainagePct                 Decimal?  @default(10.0) @map("max_retainage_pct")
  crossFileToleranceAmt           Decimal   @default(10.0) @map("cross_file_tolerance_amt")
  mathToleranceAmt                Decimal   @default(0.01) @map("math_tolerance_amt")
  confidenceThreshold             Decimal   @default(0.80) @map("confidence_threshold")
  maxPctComplete                  Decimal   @default(100.0) @map("max_pct_complete")
  periodContinuityCheck           Boolean   @default(true) @map("period_continuity_check")
  originalContractSum             Decimal?  @map("original_contract_sum")
  expectedRetainagePctDisplay     Decimal?  @map("expected_retainage_pct_display")
  customRulesJson                 String?   @map("custom_rules_json")
  notes                           String?
  configuredBy                    Int?      @map("configured_by")
  createdAt                       DateTime  @default(now()) @map("created_at")
  updatedAt                       DateTime? @updatedAt @map("updated_at")

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  configurer User?    @relation(fields: [configuredBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("contract_configs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 3 — REFERENCE / LOOKUP
// ═══════════════════════════════════════════════════════════════════════════════

model RefExceptionType {
  id                       Int     @id @default(autoincrement())
  code                     String  @unique
  displayName              String  @map("display_name")
  description              String?
  severity                 String
  routing                  String
  canBulkResolve           Boolean @default(true) @map("can_bulk_resolve")
  requiresCommentOnOverride Boolean @default(true) @map("requires_comment_on_override")
  isActive                 Boolean @default(true) @map("is_active")
  sortOrder                Int?    @default(99) @map("sort_order")

  @@map("ref_exception_types")
}

model RefDocumentType {
  id          Int     @id @default(autoincrement())
  code        String  @unique
  displayName String  @map("display_name")
  fileRole    String? @map("file_role")
  description String?
  isActive    Boolean @default(true) @map("is_active")

  @@map("ref_document_types")
}

model RefValidationRuleType {
  id                    Int     @id @default(autoincrement())
  code                  String  @unique
  displayName           String  @map("display_name")
  description           String?
  producesExceptionType String? @map("produces_exception_type")
  isActive              Boolean @default(true) @map("is_active")

  @@map("ref_validation_rule_types")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 4 — PACKAGES & DOCUMENT MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════

model Package {
  id                   Int       @id @default(autoincrement())
  clientId             Int       @map("client_id")
  contractId           Int       @map("contract_id")
  billingPeriodMonth   Int       @map("billing_period_month")
  billingPeriodYear    Int       @map("billing_period_year")
  billingPeriodLabel   String?   @map("billing_period_label")
  packageStatus        String    @default("DRAFT") @map("package_status")
  fileHash1            String?   @map("file_hash_1")
  fileHash2            String?   @map("file_hash_2")
  fileHash3            String?   @map("file_hash_3")
  totalItemsExtracted  Int?      @map("total_items_extracted")
  autoClearedCount     Int?      @map("auto_cleared_count")
  exceptionsCount      Int?      @map("exceptions_count")
  dollarAtRisk         Decimal?  @map("dollar_at_risk")
  submittedBy          Int?      @map("submitted_by")
  submittedAt          DateTime? @map("submitted_at")
  reviewedBy           Int?      @map("reviewed_by")
  reviewedAt           DateTime? @map("reviewed_at")
  approvedBy           Int?      @map("approved_by")
  approvedAt           DateTime? @map("approved_at")
  rejectionReason      String?   @map("rejection_reason")
  createdBy            Int?      @map("created_by")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime? @updatedAt @map("updated_at")

  client    Client   @relation(fields: [clientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contract  Contract @relation(fields: [contractId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  submitter User?    @relation("SubmittedByUser", fields: [submittedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reviewer  User?    @relation("ReviewedByUser", fields: [reviewedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver  User?    @relation("ApprovedByUser", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  creator   User?    @relation("CreatedByUser", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  documents             PackageDocument[]
  pipelineSteps         ProcessingPipelineStep[]
  agentPlan             AgentPlan?
  gcHeader              GcPayApplicationHeader?
  gcSovLines            GcPayApplicationSovLine[]
  subHeaders            SubPayApplicationHeader[]
  subSovLines           SubPayApplicationSovLine[]
  supportingItems       SupportingDocumentItem[]
  validationRuns        ValidationRun[]
  reconciliationResults ReconciliationResult[]
  exceptionGroups       ExceptionGroup[]
  exceptions            Exception[]
  reviewActionLogs      ReviewActionLog[]
  auditEvents           AuditEvent[]
  activityLogs          ActivityLog[]
  dataChangeLogs        DataChangeLog[]
  notifications         Notification[]
  apiIntegrationLogs    ApiIntegrationLog[]

  @@unique([contractId, billingPeriodMonth, billingPeriodYear])
  @@index([contractId])
  @@index([clientId])
  @@index([packageStatus])
  @@index([billingPeriodYear])
  @@map("packages")
}

model PackageDocument {
  id                       Int       @id @default(autoincrement())
  packageId                Int       @map("package_id")
  fileRole                 String    @map("file_role")
  originalFilename         String?   @map("original_filename")
  storedPath               String?   @map("stored_path")
  sharepointUrl            String?   @map("sharepoint_url")
  fileSizeBytes            Int?      @map("file_size_bytes")
  pageCount                Int?      @map("page_count")
  fileHash                 String?   @map("file_hash")
  mimeType                 String?   @default("application/pdf") @map("mime_type")
  uploadStatus             String    @default("PENDING") @map("upload_status")
  quarantineReason         String?   @map("quarantine_reason")
  classificationResult     String?   @map("classification_result")
  classificationConfidence Decimal?  @map("classification_confidence")
  uploadedAt               DateTime? @map("uploaded_at")
  uploadedBy               Int?      @map("uploaded_by")

  package  Package @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  uploader User?   @relation(fields: [uploadedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  pages              DocumentPage[]
  rawExtractedFields RawExtractedField[]
  supportingItems    SupportingDocumentItem[]
  sharepointRef      SharepointDocumentRef?
  exceptionsEvidence1 Exception[] @relation("EvidenceDoc1")
  exceptionsEvidence2 Exception[] @relation("EvidenceDoc2")

  @@unique([packageId, fileRole])
  @@index([packageId])
  @@index([fileRole])
  @@index([uploadStatus])
  @@map("package_documents")
}

model DocumentPage {
  id                       Int      @id @default(autoincrement())
  packageDocumentId        Int      @map("package_document_id")
  pageNo                   Int      @map("page_no")
  widthPts                 Decimal? @map("width_pts")
  heightPts                Decimal? @map("height_pts")
  rotationDegrees          Int?     @default(0) @map("rotation_degrees")
  ocrText                  String?  @map("ocr_text")
  classification           String?
  classificationConfidence Decimal? @map("classification_confidence")
  isBlank                  Boolean? @default(false) @map("is_blank")

  packageDocument PackageDocument @relation(fields: [packageDocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([packageDocumentId, pageNo])
  @@index([packageDocumentId])
  @@index([classification])
  @@map("document_pages")
}

model ProcessingPipelineStep {
  id               Int       @id @default(autoincrement())
  packageId        Int       @map("package_id")
  stepNo           Int       @map("step_no")
  stepName         String    @map("step_name")
  status           String    @default("pending")
  subProgressCurrent Int?    @map("sub_progress_current")
  subProgressTotal   Int?    @map("sub_progress_total")
  subProgressLabel   String? @map("sub_progress_label")
  startedAt        DateTime? @map("started_at")
  completedAt      DateTime? @map("completed_at")
  errorMessage     String?   @map("error_message")
  retryCount       Int?      @default(0) @map("retry_count")

  package Package @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([packageId, stepNo])
  @@index([packageId])
  @@index([status])
  @@map("processing_pipeline_steps")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 5 — AGENT PLANNING
// ═══════════════════════════════════════════════════════════════════════════════

model AgentPlan {
  id                   Int      @id @default(autoincrement())
  packageId            Int      @unique @map("package_id")
  confirmedBy          Int      @map("confirmed_by")
  confirmedAt          DateTime @map("confirmed_at")
  agentIdentifiedCount Int?     @map("agent_identified_count")
  manuallyAddedCount   Int?     @default(0) @map("manually_added_count")
  notes                String?
  createdAt            DateTime @default(now()) @map("created_at")

  package   Package         @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  confirmer User            @relation(fields: [confirmedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items     AgentPlanItem[]

  @@map("agent_plans")
}

model AgentPlanItem {
  id                Int      @id @default(autoincrement())
  agentPlanId       Int      @map("agent_plan_id")
  seqNo             Int      @map("seq_no")
  subcontractorName String   @map("subcontractor_name")
  originalOcrName   String?  @map("original_ocr_name")
  expectedAppNo     String?  @map("expected_app_no")
  billedAmountFile1 Decimal? @map("billed_amount_file1")
  gcSovLineIds      String?  @map("gc_sov_line_ids")
  source            String   @default("AGENT")
  isManuallyAdded   Boolean  @default(false) @map("is_manually_added")
  notes             String?

  agentPlan  AgentPlan                @relation(fields: [agentPlanId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  gcSovLines GcPayApplicationSovLine[]
  subHeaders SubPayApplicationHeader[]

  @@index([agentPlanId])
  @@index([source])
  @@map("agent_plan_items")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 6 — AI EXTRACTION STAGING
// ═══════════════════════════════════════════════════════════════════════════════

model RawExtractedField {
  id                    Int      @id @default(autoincrement())
  packageDocumentId     Int      @map("package_document_id")
  agentRunId            String?  @map("agent_run_id")
  pageNo                Int?     @map("page_no")
  fieldName             String?  @map("field_name")
  fieldCategory         String?  @map("field_category")
  rawValue              String?  @map("raw_value")
  normalizedValue       String?  @map("normalized_value")
  bboxX                 Decimal? @map("bbox_x")
  bboxY                 Decimal? @map("bbox_y")
  bboxWidth             Decimal? @map("bbox_width")
  bboxHeight            Decimal? @map("bbox_height")
  extractionConfidence  Decimal? @map("extraction_confidence")
  isTableCell           Boolean? @default(false) @map("is_table_cell")
  tableRowNo            Int?     @map("table_row_no")
  tableColName          String?  @map("table_col_name")
  createdAt             DateTime @default(now()) @map("created_at")

  packageDocument PackageDocument @relation(fields: [packageDocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dataChangeLogs  DataChangeLog[]

  @@index([packageDocumentId])
  @@index([agentRunId])
  @@index([pageNo])
  @@index([fieldName])
  @@index([extractionConfidence])
  @@map("raw_extracted_fields")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 7 — CONTRACTOR DATA (FILE 1)
// ═══════════════════════════════════════════════════════════════════════════════

model GcPayApplicationHeader {
  id                     Int       @id @default(autoincrement())
  packageId              Int       @unique @map("package_id")
  agentRunId             String?   @map("agent_run_id")
  toOwner                String?   @map("to_owner")
  fromContractor         String?   @map("from_contractor")
  projectName            String?   @map("project_name")
  applicationNo          String?   @map("application_no")
  period                 String?
  periodFrom             String?   @map("period_from")
  periodTo               String?   @map("period_to")
  originalContractSum    Decimal?  @map("original_contract_sum")
  netChangeOrders        Decimal?  @map("net_change_orders")
  contractSumToDate      Decimal?  @map("contract_sum_to_date")
  totalCompletedStored   Decimal?  @map("total_completed_stored")
  retainageCompleted     Decimal?  @map("retainage_completed")
  retainageMaterials     Decimal?  @map("retainage_materials")
  totalRetainage         Decimal?  @map("total_retainage")
  totalEarnedLessRet     Decimal?  @map("total_earned_less_ret")
  lessPrevCertificates   Decimal?  @map("less_prev_certificates")
  currentPaymentDue      Decimal?  @map("current_payment_due")
  balanceToFinish        Decimal?  @map("balance_to_finish")
  changeOrderSummary     String?   @map("change_order_summary")
  architectSignature     String?   @map("architect_signature")
  contractorSignature    String?   @map("contractor_signature")
  sourcePage             Int?      @map("source_page")
  extractionConfidence   Decimal?  @map("extraction_confidence")
  bboxX                  Decimal?  @map("bbox_x")
  bboxY                  Decimal?  @map("bbox_y")
  bboxWidth              Decimal?  @map("bbox_width")
  bboxHeight             Decimal?  @map("bbox_height")
  reviewNotes            String?   @map("review_notes")
  validationStatus       String?   @default("unchecked") @map("validation_status")
  validationNotes        String?   @map("validation_notes")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime? @updatedAt @map("updated_at")

  package Package @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("gc_pay_application_headers")
}

model GcPayApplicationSovLine {
  id                    Int       @id @default(autoincrement())
  packageId             Int       @map("package_id")
  agentPlanItemId       Int?      @map("agent_plan_item_id")
  itemNo                String?   @map("item_no")
  timePeriod            String?   @map("time_period")
  phases                String?
  typeOfWork            String?   @map("type_of_work")
  contractorName        String?   @map("contractor_name")
  scheduledOriginal     Decimal?  @default(0) @map("scheduled_original")
  scheduledChangeOrders Decimal?  @default(0) @map("scheduled_change_orders")
  scheduledCurrent      Decimal?  @default(0) @map("scheduled_current")
  workCompletedPrev     Decimal?  @default(0) @map("work_completed_prev")
  workCompletedThis     Decimal?  @default(0) @map("work_completed_this")
  materialsStored       Decimal?  @default(0) @map("materials_stored")
  totalCompleted        Decimal?  @default(0) @map("total_completed")
  pct                   Decimal?  @default(0) @map("pct")
  balanceToFinish       Decimal?  @default(0) @map("balance_to_finish")
  retainage             Decimal?  @default(0) @map("retainage")
  file2ExtractedAmount  Decimal?  @map("file2_extracted_amount")
  crossFileVariance     Decimal?  @map("cross_file_variance")
  file2MatchedSubAppId  Int?      @map("file2_matched_sub_app_id")
  sourcePage            Int?      @map("source_page")
  extractionConfidence  Decimal?  @map("extraction_confidence")
  bboxPage              Int?      @map("bbox_page")
  bboxX                 Decimal?  @map("bbox_x")
  bboxY                 Decimal?  @map("bbox_y")
  bboxWidth             Decimal?  @map("bbox_width")
  bboxHeight            Decimal?  @map("bbox_height")
  reviewNotes           String?   @map("review_notes")
  validationStatus      String?   @default("unchecked") @map("validation_status")
  validationNote        String?   @map("validation_note")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime? @updatedAt @map("updated_at")

  package        Package              @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agentPlanItem  AgentPlanItem?        @relation(fields: [agentPlanItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  matchedSubApp  SubPayApplicationHeader? @relation(fields: [file2MatchedSubAppId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supportingItems SupportingDocumentItem[]

  @@index([packageId])
  @@index([contractorName])
  @@index([validationStatus])
  @@index([agentPlanItemId])
  @@map("gc_pay_application_sov_lines")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 8 — SUB-CONTRACTOR DATA (FILE 2)
// ═══════════════════════════════════════════════════════════════════════════════

model SubPayApplicationHeader {
  id                        Int       @id @default(autoincrement())
  packageId                 Int       @map("package_id")
  agentPlanItemId           Int?      @map("agent_plan_item_id")
  seqId                     Int?      @map("seq_id")
  startPage                 Int?      @map("start_page")
  endPage                   Int?      @map("end_page")
  documentType              String?   @map("document_type")
  documentCategory          String?   @map("document_category")
  subcontractorName         String?   @map("subcontractor_name")
  applicationNo             String?   @map("application_no")
  applicationDate           String?   @map("application_date")
  periodFrom                String?   @map("period_from")
  periodTo                  String?   @map("period_to")
  invoiceTo                 String?   @map("invoice_to")
  projectNameOnDoc          String?   @map("project_name_on_doc")
  contractPoNumber          String?   @map("contract_po_number")
  originalContractSum       Decimal?  @map("original_contract_sum")
  netChangeOrders           Decimal?  @map("net_change_orders")
  contractSumToDate         Decimal?  @map("contract_sum_to_date")
  totalCompletedStored      Decimal?  @map("total_completed_stored")
  completedWorkThisPeriod   Decimal?  @map("completed_work_this_period")
  totalRetainage            Decimal?  @map("total_retainage")
  retainagePercent          Decimal?  @map("retainage_percent")
  totalEarnedLessRetainage  Decimal?  @map("total_earned_less_retainage")
  lessPrevCertificates      Decimal?  @map("less_prev_certificates")
  currentPaymentDue         Decimal?  @map("current_payment_due")
  balanceToFinish           Decimal?  @map("balance_to_finish")
  g703ScheduledValue        Decimal?  @map("g703_scheduled_value")
  g703WorkPrev              Decimal?  @map("g703_work_prev")
  g703WorkThisPeriod        Decimal?  @map("g703_work_this_period")
  g703MaterialsStored       Decimal?  @map("g703_materials_stored")
  g703TotalCompleted        Decimal?  @map("g703_total_completed")
  g703Retainage             Decimal?  @map("g703_retainage")
  g703EarnedLessRet         Decimal?  @map("g703_earned_less_ret")
  g703BalanceToFinish       Decimal?  @map("g703_balance_to_finish")
  reconFlag                 String?   @map("recon_flag")
  contractorSignature       String?   @map("contractor_signature")
  architectSignature        String?   @map("architect_signature")
  notarized                 String?
  additionalSupportingDocs  String?   @map("additional_supporting_docs")
  extractionConfidence      Decimal?  @map("extraction_confidence")
  validationStatus          String?   @default("unchecked") @map("validation_status")
  validationNote            String?   @map("validation_note")
