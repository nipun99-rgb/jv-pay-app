// FAMILY 14 — EXTERNAL INTEGRATION
// ═══════════════════════════════════════════════════════════════════════════════

model ApiIntegrationLog {
  id                       Int      @id @default(autoincrement())
  packageId                Int?     @map("package_id")
  serviceName              String   @map("service_name")
  operation                String
  requestUrl               String?  @map("request_url")
  httpMethod               String?  @map("http_method")
  requestPayloadSizeBytes  Int?     @map("request_payload_size_bytes")
  responseStatusCode       Int?     @map("response_status_code")
  responsePayloadSizeBytes Int?     @map("response_payload_size_bytes")
  durationMs               Int?     @map("duration_ms")
  success                  Boolean
  errorCode                String?  @map("error_code")
  errorMessage             String?  @map("error_message")
  tokensUsed               Int?     @map("tokens_used")
  costEstimateUsd          Decimal? @map("cost_estimate_usd")
  agentRunId               String?  @map("agent_run_id")
  createdAt                DateTime @default(now()) @map("created_at")

  package Package? @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([packageId])
  @@index([serviceName])
  @@index([success])
  @@index([createdAt])
  @@map("api_integration_logs")
}

model SharepointDocumentRef {
  id                 Int       @id @default(autoincrement())
  packageDocumentId  Int       @unique @map("package_document_id")
  sharepointSiteId   String?   @map("sharepoint_site_id")
  sharepointDriveId  String?   @map("sharepoint_drive_id")
  sharepointItemId   String?   @map("sharepoint_item_id")
  sharepointUrl      String?   @map("sharepoint_url")
  sharepointVersion  String?   @map("sharepoint_version")
  uploadedAt         DateTime? @map("uploaded_at")
  lastSyncedAt       DateTime? @map("last_synced_at")
  retentionLabel     String?   @map("retention_label")
  createdAt          DateTime  @default(now()) @map("created_at")

  packageDocument PackageDocument @relation(fields: [packageDocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([sharepointItemId])
  @@map("sharepoint_document_refs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 15 — SYSTEM CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════════

model SystemConfig {
  id          Int       @id @default(autoincrement())
  configKey   String    @unique @map("config_key")
  configValue String    @map("config_value")
  dataType    String    @map("data_type")
  description String?
  isSensitive Boolean   @default(false) @map("is_sensitive")
  updatedBy   Int?      @map("updated_by")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  updater User? @relation(fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("system_configs")
}
