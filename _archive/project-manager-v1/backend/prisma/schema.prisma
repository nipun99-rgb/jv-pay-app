// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 10 — VALIDATION ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

model ValidationRun {
  id                       Int       @id @default(autoincrement())
  packageId                Int       @map("package_id")
  runNumber                Int       @map("run_number")
  triggeredBy              Int?      @map("triggered_by")
  runStatus                String    @default("RUNNING") @map("run_status")
  runStartedAt             DateTime  @default(now()) @map("run_started_at")
  runCompletedAt           DateTime? @map("run_completed_at")
  totalItems               Int?      @map("total_items")
  autoClearedCount         Int?      @map("auto_cleared_count")
  exceptionsCount          Int?      @map("exceptions_count")
  blockingExceptionsCount  Int?      @map("blocking_exceptions_count")
  dollarAtRisk             Decimal?  @map("dollar_at_risk")
  errorMessage             String?   @map("error_message")
  createdAt                DateTime  @default(now()) @map("created_at")

  package              Package               @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  triggeredByUser      User?                 @relation(fields: [triggeredBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reconciliationResults ReconciliationResult[]
  exceptionGroups      ExceptionGroup[]
  exceptions           Exception[]

  @@index([packageId])
  @@index([runStatus])
  @@map("validation_runs")
}

model ReconciliationResult {
  id                 Int      @id @default(autoincrement())
  packageId          Int      @map("package_id")
  validationRunId    Int      @map("validation_run_id")
  reconciliationType String   @map("reconciliation_type")
  entityType         String?  @map("entity_type")
  entityId           Int?     @map("entity_id")
  jvAmount           Decimal? @map("jv_amount")
  subAmount          Decimal? @map("sub_amount")
  expectedAmount     Decimal? @map("expected_amount")
  computedAmount     Decimal? @map("computed_amount")
  variance           Decimal?
  toleranceApplied   Decimal? @map("tolerance_applied")
  passed             Boolean
  failureReason      String?  @map("failure_reason")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")

  package       Package       @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  validationRun ValidationRun @relation(fields: [validationRunId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([packageId])
  @@index([validationRunId])
  @@index([entityType])
  @@index([passed])
  @@map("reconciliation_results")
}

model ExceptionGroup {
  id                Int       @id @default(autoincrement())
  packageId         Int       @map("package_id")
  validationRunId   Int       @map("validation_run_id")
  exceptionTypeCode String    @map("exception_type_code")
  displayLabel      String    @map("display_label")
  severity          String
  itemCount         Int       @default(0) @map("item_count")
  resolvedCount     Int       @default(0) @map("resolved_count")
  dollarAtRisk      Decimal   @default(0) @map("dollar_at_risk")
  status            String    @default("open")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  package       Package       @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  validationRun ValidationRun @relation(fields: [validationRunId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  exceptions    Exception[]

  @@index([packageId])
  @@index([exceptionTypeCode])
  @@index([status])
  @@map("exception_groups")
}

model Exception {
  id                   Int       @id @default(autoincrement())
  packageId            Int       @map("package_id")
  validationRunId      Int       @map("validation_run_id")
  exceptionGroupId     Int?      @map("exception_group_id")
  exceptionTypeCode    String    @map("exception_type_code")
  entityType           String?   @map("entity_type")
  entityId             Int?      @map("entity_id")
  title                String
  description          String?
  file1Value           Decimal?  @map("file1_value")
  file2Value           Decimal?  @map("file2_value")
  expectedValue        Decimal?  @map("expected_value")
  variance             Decimal? 
  dollarAtRisk         Decimal?  @map("dollar_at_risk")
  extractionConfidence Decimal?  @map("extraction_confidence")
  riskRank             Int?      @map("risk_rank")
  status               String    @default("open")
  evidenceDocumentId   Int       @map("evidence_document_id")
  evidencePageNo       Int?      @map("evidence_page_no")
  evidenceBboxX        Decimal?  @map("evidence_bbox_x")
  evidenceBboxY        Decimal?  @map("evidence_bbox_y")
  evidenceBboxWidth    Decimal?  @map("evidence_bbox_width")
  evidenceBboxHeight   Decimal?  @map("evidence_bbox_height")
  evidence2DocumentId  Int?      @map("evidence2_document_id")
  evidence2PageNo      Int?      @map("evidence2_page_no")
  evidence2BboxX       Decimal?  @map("evidence2_bbox_x")
  evidence2BboxY       Decimal?  @map("evidence2_bbox_y")
  evidence2BboxWidth   Decimal?  @map("evidence2_bbox_width")
  evidence2BboxHeight  Decimal?  @map("evidence2_bbox_height")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime? @updatedAt @map("updated_at")

  package           Package          @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  validationRun     ValidationRun    @relation(fields: [validationRunId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  exceptionGroup    ExceptionGroup?  @relation(fields: [exceptionGroupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  evidenceDocument  PackageDocument  @relation("EvidenceDoc1", fields: [evidenceDocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  evidence2Document PackageDocument? @relation("EvidenceDoc2", fields: [evidence2DocumentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resolutions       ExceptionResolution[]

  @@index([packageId])
  @@index([exceptionTypeCode])
  @@index([exceptionGroupId])
  @@index([status])
  @@index([riskRank])
  @@index([entityType])
  @@map("exceptions")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 11 — REVIEW & RESOLUTION
// ═══════════════════════════════════════════════════════════════════════════════

model ExceptionResolution {
  id              Int       @id @default(autoincrement())
  exceptionId     Int       @map("exception_id")
  resolvedBy      Int       @map("resolved_by")
  resolvedAt      DateTime  @map("resolved_at")
  resolutionType  String    @map("resolution_type")
  overrideValue   Decimal?  @map("override_value")
  overrideField   String?   @map("override_field")
  comment         String?
  escalatedToRole String?   @map("escalated_to_role")
  createdAt       DateTime  @default(now()) @map("created_at")

  exception Exception @relation(fields: [exceptionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resolver  User      @relation(fields: [resolvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([exceptionId])
  @@index([resolvedBy])
  @@index([resolutionType])
  @@map("exception_resolutions")
}

model ReviewActionLog {
  id          Int      @id @default(autoincrement())
  packageId   Int      @map("package_id")
  userId      Int      @map("user_id")
  actionType  String   @map("action_type")
  entityType  String?  @map("entity_type")
  entityId    Int?     @map("entity_id")
  beforeValue String?  @map("before_value")
  afterValue  String?  @map("after_value")
  comment     String?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  package Package @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user    User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([packageId])
  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
  @@map("review_action_logs")
}

