model AuditEvent {
  id           Int      @id @default(autoincrement())
  packageId    Int      @map("package_id")
  eventType    String   @map("event_type")
  triggeredBy  Int      @map("triggered_by")
  triggeredAt  DateTime @map("triggered_at")
  eventSummary String?  @map("event_summary")
  createdAt    DateTime @default(now()) @map("created_at")

  package Package @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user    User    @relation(fields: [triggeredBy], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([packageId])
  @@index([eventType])
  @@index([triggeredAt])
  @@map("audit_events")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  packageId Int      @map("package_id")
  level     String   @default("info")
  stepNo    Int?     @map("step_no")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  package Package @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([packageId])
  @@index([stepNo])
  @@index([createdAt])
  @@map("activity_logs")
}

model DataChangeLog {
  id            Int      @id @default(autoincrement())
  packageId     Int      @map("package_id")
  entityType    String   @map("entity_type")
  entityId      Int      @map("entity_id")
  fieldName     String   @map("field_name")
  originalValue String?  @map("original_value")
  newValue      String?  @map("new_value")
  changedBy     Int      @map("changed_by")
  changedAt     DateTime @map("changed_at")
  reason        String
  rawFieldId    Int?     @map("raw_field_id")
  createdAt     DateTime @default(now()) @map("created_at")

  package  Package            @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  changer  User               @relation(fields: [changedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rawField RawExtractedField? @relation(fields: [rawFieldId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([packageId])
  @@index([entityType])
  @@index([changedBy])
  @@index([changedAt])
  @@map("data_change_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// FAMILY 13 — NOTIFICATIONS
// ═══════════════════════════════════════════════════════════════════════════════

model Notification {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  packageId        Int?      @map("package_id")
  notificationType String    @map("notification_type")
  title            String
  message          String
  actionUrl        String?   @map("action_url")
  isRead           Boolean   @default(false) @map("is_read")
  readAt           DateTime? @map("read_at")
  emailSent        Boolean   @default(false) @map("email_sent")
  emailSentAt      DateTime? @map("email_sent_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  package Package? @relation(fields: [packageId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([packageId])
  @@map("notifications")
}

model NotificationPreference {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  notificationType String    @map("notification_type")
  inAppEnabled     Boolean   @default(true) @map("in_app_enabled")
  emailEnabled     Boolean   @default(false) @map("email_enabled")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, notificationType])
  @@map("notification_preferences")
}

