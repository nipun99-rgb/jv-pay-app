  packageDocumentId    Int       @map("package_document_id")
  pageNo               Int?      @map("page_no")
  documentType         String?   @map("document_type")
  vendorName           String?   @map("vendor_name")
  invoiceDate          String?   @map("invoice_date")
  invoiceNo            String?   @map("invoice_no")
  description          String?
  amount               Decimal? 
  currency             String?   @default("USD")
  taxAmount            Decimal?  @map("tax_amount")
  totalAmount          Decimal?  @map("total_amount")
  linkedSovLineId      Int?      @map("linked_sov_line_id")
  matchConfidence      Decimal?  @map("match_confidence")
  matchMethod          String?   @map("match_method")
  extractionConfidence Decimal?  @map("extraction_confidence")
  bboxPage             Int?      @map("bbox_page")
  bboxX                Decimal?  @map("bbox_x")
  bboxY                Decimal?  @map("bbox_y")
  bboxWidth            Decimal?  @map("bbox_width")
  bboxHeight           Decimal?  @map("bbox_height")
