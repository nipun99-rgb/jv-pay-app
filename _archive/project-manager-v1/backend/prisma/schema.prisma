  workCompletedPrev    Decimal?  @map("work_completed_prev")
  workCompletedThis    Decimal?  @map("work_completed_this")
  materialsStored      Decimal?  @map("materials_stored")
  totalCompleted       Decimal?  @map("total_completed")
  pctComplete          Decimal?  @map("pct_complete")
  retainage            Decimal?  @map("retainage")
  balanceToFinish      Decimal?  @map("balance_to_finish")
  extractionConfidence Decimal?  @map("extraction_confidence")
  bboxPage             Int?      @map("bbox_page")
